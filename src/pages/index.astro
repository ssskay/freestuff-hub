---
import Base from '../layouts/Base.astro';
import { SITE, SCHOOLS, fundingLink } from '../site.config';

const tip = fundingLink();
const title = `${SITE.name} — verified free perks at your school`;
const description = SITE.tagline;

const origin = SITE.url;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${origin}/#website`,
      url: origin,
      name: SITE.name,
      description: SITE.tagline,
    },
    {
      '@type': 'Organization',
      '@id': `${origin}/#org`,
      name: SITE.name,
      url: origin,
      description:
        'A trust-based, ad-free catalog of things that are genuinely free for students, one verified catalog per campus.',
      sameAs: [SITE.template],
    },
  ],
};
---

<Base title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <main id="main" tabindex="-1">
    <section class="hero">
      <p class="eyebrow">An independent, student-built platform</p>
      <h1 class="hero-title">{SITE.name}</h1>
      <p class="hero-deck">{SITE.tagline}</p>
      <div class="hero-actions">
        <a href="#schools" class="btn btn-primary">Find your school</a>
        <a href={SITE.template} class="btn btn-ghost" rel="noopener" target="_blank">Bring it to your campus</a>
      </div>
    </section>

    <section id="schools" class="schools" aria-labelledby="schools-heading">
      <h2 id="schools-heading" class="section-heading">Live schools</h2>
      <ul class="school-grid" role="list">
        {SCHOOLS.map((s) => (
          <li>
            <a class="school-card" href={s.url} rel="noopener">
              <span class="school-monogram" style={`--mono: ${s.accent ?? 'var(--color-accent)'}`}>{s.monogram}</span>
              <span class="school-body">
                <span class="school-name">Free Stuff @ {s.name}</span>
                <span class="school-host">{s.url.replace('https://', '')}</span>
              </span>
              <span class="school-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </li>
        ))}
        <li>
          <a class="school-card school-card-cta" href={SITE.template} rel="noopener" target="_blank">
            <span class="school-monogram school-monogram-cta" aria-hidden="true">+</span>
            <span class="school-body">
              <span class="school-name">Don't see your school?</span>
              <span class="school-host">Bring this to your campus &rarr; the open template</span>
            </span>
          </a>
        </li>
      </ul>
    </section>

    <section class="support" aria-labelledby="support-heading">
      <h2 id="support-heading" class="section-heading">Keep it free, keep it honest</h2>
      <p class="support-copy">
        No ads, no affiliate links, no data resold — every perk is verified and shown with its real source.
        A small tip covers the domain and keeps the catalogs current.
      </p>
      {tip && (
        <a class="btn btn-primary" href={tip.href} rel="noopener" target="_blank">{tip.label}</a>
      )}
    </section>
  </main>

  <style>
    .hero {
      padding: var(--space-3xl) 0 var(--space-2xl);
      max-width: var(--measure);
    }
    .eyebrow {
      margin: 0 0 var(--space-sm);
      font-size: var(--text-sm);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--color-accent);
    }
    .hero-title {
      font-family: var(--font-display);
      font-size: var(--text-5xl);
      line-height: var(--leading-tight);
      font-weight: 600;
      color: var(--color-ink);
      margin: 0 0 var(--space-md);
    }
    .hero-deck {
      font-size: var(--text-xl);
      line-height: var(--leading-snug);
      color: var(--color-ink-muted);
      margin: 0 0 var(--space-xl);
    }
    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-sm);
    }

    .schools {
      padding: var(--space-xl) 0;
      border-top: var(--rule-thin) solid var(--color-border);
    }
    .school-grid {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
      gap: var(--space-md);
    }
    .school-card {
      display: flex;
      align-items: center;
      gap: var(--space-md);
      padding: var(--space-md);
      border: var(--rule-thin) solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-paper);
      text-decoration: none;
      transition: border-color var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
    }
    .school-card:hover {
      border-color: var(--color-border-strong);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
    }
    .school-monogram {
      flex: none;
      display: grid;
      place-items: center;
      width: 3rem;
      height: 3rem;
      border-radius: var(--radius-md);
      background: var(--mono, var(--color-accent));
      color: var(--color-paper);
      font-family: var(--font-body);
      font-weight: 700;
      font-size: var(--text-sm);
    }
    .school-monogram-cta {
      background: transparent;
      color: var(--color-ink-subtle);
      border: var(--rule-base) dashed var(--color-border-strong);
      font-size: var(--text-2xl);
      font-weight: 400;
    }
    .school-body {
      display: flex;
      flex-direction: column;
      gap: var(--space-3xs);
      min-width: 0;
    }
    .school-name { font-size: var(--text-lg); font-weight: 600; color: var(--color-ink); }
    .school-host { font-size: var(--text-sm); color: var(--color-ink-subtle); }
    .school-arrow { margin-left: auto; font-size: var(--text-xl); color: var(--color-accent); }
    .school-card-cta { border-style: dashed; background: var(--color-paper-2); }

    .support {
      padding: var(--space-2xl) 0;
      border-top: var(--rule-thin) solid var(--color-border);
      max-width: var(--measure);
    }
    .support-copy {
      font-size: var(--text-lg);
      line-height: var(--leading-relaxed);
      color: var(--color-ink-muted);
      margin: 0 0 var(--space-lg);
    }

    @media (max-width: 768px) {
      .hero { padding: var(--space-2xl) 0 var(--space-xl); }
      .hero-title { font-size: var(--text-4xl); }
    }
  </style>
</Base>
